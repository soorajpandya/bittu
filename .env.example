# ══════════════════════════════════════════════════════════════
# BITTU — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ══════════════════════════════════════════════════════════════

# ── App ──
APP_NAME=BITTU
APP_ENV=development          # development | staging | production
ENVIRONMENT=development
DEBUG=false                  # MUST be false in production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["*"]
SECRET_KEY=                  # Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Database (Supabase Postgres) ──
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_DIRECT_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300
DB_STATEMENT_TIMEOUT=30000

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ── Razorpay ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── PhonePe ──
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
PHONEPE_MODE=sandbox         # sandbox | live

# ── PayU ──
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_MODE=test               # test | live

# ── Paytm ──
PAYTM_MID=
PAYTM_MERCHANT_KEY=
PAYTM_WEBSITE=WEBSTAGING
PAYTM_MODE=test              # test | live

# ── Cashfree PG ──
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_MODE=sandbox        # sandbox | live

# ── Cashfree Verification / KYC ──
CF_VERIFY_CLIENT_ID=
CF_VERIFY_CLIENT_SECRET=
CF_VERIFY_PUBLIC_KEY=
CF_VERIFY_MODE=sandbox       # sandbox | production

# ── Cashfree 1-Click Onboarding ──
CF_ONECLICK_CLIENT_ID=
CF_ONECLICK_CLIENT_SECRET=

# ── Cashfree DigiLocker ──
CF_DIGILOCKER_CLIENT_ID=
CF_DIGILOCKER_CLIENT_SECRET=
CF_DIGILOCKER_MODE=sandbox   # sandbox | live

# ── Zivonpay ──
ZIVONPAY_MERCHANT_ID=
ZIVONPAY_API_KEY=
ZIVONPAY_API_SECRET=
ZIVONPAY_MODE=sandbox        # sandbox | live

# ── ElevenLabs TTS ──
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=xoV6iGVuOGYHLWjXhVC7

# ── OpenAI ──
OPENAI_API_KEY=

# ── Google Cloud Vision ──
GOOGLE_VISION_API_KEY=

# ── Upstash Redis (REST) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=20

# ── Deployment ──
WORKERS=4
GRACEFUL_SHUTDOWN_TIMEOUT=30
TRUSTED_PROXIES=["127.0.0.1"]
