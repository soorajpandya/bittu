# ── Environment ──
.env
.env.local
.env.production
.env.staging
!.env.example

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environment ──
venv/
.venv/
env/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── Testing ──
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── OS ──
.DS_Store
Thumbs.db

# ── Docker ──
*.log

# ── SSL Certs (never commit) ──
deploy/nginx/ssl/
nginx/ssl/
*.pem
*.key
*.crt

# ── Disposable / one-shot dev scripts ──
# Anything prefixed with _ at the repo root is local-only scratch
# (migration runners, smoke tests, inspection scripts, etc.)
/_*.py
/_*.sh
/_*.txt
/_*.json
/scrap.py
/check_*.py
/fix_*.py
