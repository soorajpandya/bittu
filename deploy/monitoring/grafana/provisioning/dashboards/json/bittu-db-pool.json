{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Bittu Backend — DB & Pool",
  "uid": "bittu-db-pool",
  "tags": ["bittu", "database"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Pool acquire wait — p50 / p95 / p99 by txn_kind",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, txn_kind) (rate(db_pool_acquire_wait_seconds_bucket[5m])))",
          "legendFormat": "p50 {{txn_kind}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, txn_kind) (rate(db_pool_acquire_wait_seconds_bucket[5m])))",
          "legendFormat": "p95 {{txn_kind}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, txn_kind) (rate(db_pool_acquire_wait_seconds_bucket[5m])))",
          "legendFormat": "p99 {{txn_kind}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "type": "timeseries",
      "title": "SERIALIZABLE retries by function (rate/s)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "sum by (function) (rate(db_txn_serialization_retries_total[5m]))",
          "legendFormat": "{{function}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "type": "timeseries",
      "title": "SERIALIZABLE retries by sqlstate",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "expr": "sum by (sqlstate) (rate(db_txn_serialization_retries_total[5m]))",
          "legendFormat": "{{sqlstate}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "type": "stat",
      "title": "Pool acquire p99 (transaction)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(db_pool_acquire_wait_seconds_bucket{txn_kind=\"transaction\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "type": "stat",
      "title": "Retry rate (total/s, 1m)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 18 },
      "targets": [
        {
          "expr": "sum(rate(db_txn_serialization_retries_total[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "type": "stat",
      "title": "API up",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 18 },
      "targets": [
        { "expr": "up{job=\"bittu-api\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    }
  ]
}
